---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import ComponentsTable from '../components/ComponentsTable.vue';

// Each component's page route matches its name exactly (e.g. DXDashboard →
// /components/extended/DXDashboard). Derive the link from the name and prefix
// the configured base path so the table links can't drift out of case with the
// pages or drop the base path — both of which 404'd before (the URLs were
// hardcoded lowercase and unprefixed).
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const extendedComponents = [
  {
    name: 'DXDashboard',
    description: 'Complete dashboard layout combining sidebar, navbar, and content area with state management',
  },
  {
    name: 'DXDashboardNavbar',
    description: 'Top navigation bar with hamburger menu, page title, and user dropdown',
  },
  {
    name: 'DXDashboardSidebar',
    description: 'Responsive collapsible sidebar with navigation, localStorage persistence, and custom branding',
  },
  {
    name: 'DXForm',
    description: 'Form renderer from field definitions, with optional tabs, conditional fields, per-field slots, async options, and nested repeaters',
  },
  {
    name: 'DXField',
    description: 'Single-field renderer for any field type, with value/span/info/hint slots',
  },
  {
    name: 'DXRepeater',
    description: 'Repeatable nested sub-form (field array) for dynamic collections',
  },
  {
    name: 'DXStatCard',
    description: 'Stat/metric card with label, value, trend indicator, and optional icon',
  },
  {
    name: 'DXSwitch',
    description: 'Filled-box toggle switch (label + toggle, primary on-state), used standalone or as the DXField switch field',
  },
  {
    name: 'DXUserAvatar',
    description: 'Circular user avatar (initial on a disc) with an optional notification dot — the navbar user-icon default',
  },
  {
    name: 'DXChart',
    description: 'Themed chart wrappers (DXBarChart, DXLineChart, DXDoughnutChart) built on chart.js',
  },
  {
    name: 'DXTable',
    description: 'Data table with pagination, sorting, and custom cell rendering',
  },
];
const components = extendedComponents.map((component) => ({
  ...component,
  type: 'Extended',
  url: `${base}/components/extended/${component.name}`,
}));

const fields = [
  { key: 'name', label: 'Component', sortable: true },
  { key: 'description', label: 'Description' },
  { key: 'type', label: 'Type' },
];
---

<DashboardLayout title="Components">
  <div class="components-page">
    <h1>Component Library</h1>
    <p class="lead">
      Dashboard for Laravel provides extended dashboard components and type-safe wrappers around Bootstrap Vue Next.
    </p>

    <section class="section">
      <h2>Extended Components</h2>
      <p>Dashboard-ready components built specifically for Laravel applications:</p>

      <ComponentsTable client:load components={components} />
    </section>

    <section class="section">
      <h2>Base Components</h2>
      <p>
        Type-safe wrappers around Bootstrap Vue Next components with dynamic slot forwarding and API stability.
        All 55 base components (D* prefix) forward props, events, and slots from their Bootstrap Vue Next counterparts.
      </p>
      <p>
        <a href={`${import.meta.env.BASE_URL}/components/base/DButton`}>View all base components →</a>
      </p>
      <p class="text-muted">
        For complete API documentation of base components, refer to the
        <a href="https://bootstrap-vue-next.github.io/bootstrap-vue-next/" target="_blank" rel="noopener">
          Bootstrap Vue Next documentation
        </a>.
      </p>
    </section>
  </div>
</DashboardLayout>

<style>
  .components-page {
    max-width: 1200px;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--bs-secondary);
    margin-bottom: 2rem;
  }

  .section {
    margin-top: 3rem;
  }

  .section h2 {
    font-size: 1.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--bs-dark);
  }

  .section p {
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  :global(.components-table) {
    margin-top: 1.5rem;
  }

  .text-muted {
    color: var(--bs-secondary);
    font-size: 0.875rem;
  }
</style>
