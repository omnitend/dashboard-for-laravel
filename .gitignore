# Dependencies
# No trailing slash: parallel-agent git worktrees symlink `node_modules` back to
# the primary checkout, and `node_modules/` matches only a real directory — so a
# symlink stayed untracked-but-visible, one `git add -A` away from being committed.
node_modules
/vendor
composer.lock

# Environment files
.env
.env.local
.env.*.local

# Build output
/dist
/docs/dist
*.map
.astro/
docs/.astro/

# Auto-generated (unplugin-vue-components global declarations)
components.d.ts

# Testing
.vitest-attachments/

